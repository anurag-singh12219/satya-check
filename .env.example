# Copy this file to .env and fill the values

# Required for ScaleDown compression
SCALEDOWN_API_KEY=
SCALEDOWN_URL=https://api.scaledown.xyz/compress/raw/

# Optional for live news ingestion
NEWS_API_KEY=

# Optional API security key (when set, send x-api-key from clients)
APP_API_KEY=

# Hybrid RAG retrieval controls
ENABLE_SEMANTIC_RAG=0
SEMANTIC_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K_SMART=60
RAG_TOP_K_NAIVE=120

# Optional social monitoring handles (comma-separated, no @)
SOCIAL_X_HANDLES=PIBFactCheck,RBI
SOCIAL_INSTAGRAM_HANDLES=pib_india

# Workshop metric pricing assumption
INPUT_COST_PER_1K=0.0025
